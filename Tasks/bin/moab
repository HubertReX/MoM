#!/usr/bin/env python3
"""moab — MOAB board CLI. The board (board.md) is the SOURCE OF TRUTH.

Agents drive the board through these COMMANDS — never by hand-editing markdown
(small models loop on exact-match edits). Every mutating command updates board.md
and then syncs the derived fields into the task notes' frontmatter.

Commands:
  moab new    "<title>" --type <t> --prio <p> [--lane backlog|ready] [--raw] [--due YYYY-MM-DD]
              Create a task: note from template + card on the board + sync. Prints the new id.
  moab claim  <id> --agent <name>
              Move card to In Progress, tag #<agent>, log, sync.
  moab review <id> [--agent n] [--note "<summary>"]
              Move to Needs You, tag #review, log, sync.
  moab block  <id> [--agent n] [--note "<question>"]
              Move to Needs You, tag #blocked, log, sync.
  moab move   <id> --to <lane> [--agent n] [--review|--blocked|--raw]
              Generic move + sync.
  moab done   <id>
              Move card to Done, sync.
  moab retag  <id> [--prio pX] [--type T] [--add tag] [--remove tag]
              Edit a card's tags + sync.
  moab rm     <id>
              Delete the card from the board and its note.
  moab log    <id> --agent <name> --note "<text>"
              Append a line to the note's Agent Log.
  moab sync   [--check]
              Derive note frontmatter from the board (--check: dry, exit 1 on drift).
  moab status
              Per-lane summary.

   moab install <project-dir> [--with-plugins] [--with-theme] [--hook] [--keep-demo]
                [--project-name <name>]
                Drop MOAB into another repo: copy Tasks/ there, optionally Kanban+Dataview
                plugins / Obsidianite theme / a pre-commit hook; clears demo cards.
                Project name is auto-detected (git remote → folder) or set via --project-name.
    moab assign  <id> --agent <name> [--model <m>] [--long] [--run]
                Print (or --run) a ready `opencode run` command that claims + works the task.
                Without --long: just claim. With --long: full implementation instructions.
                With --agent opencode also sets --dangerously-skip-permissions and --title.
    moab watch  --agent <name> [--model <m>] [--interval 10] [--limit 1]
                Loop: if a Ready for AI card exists and In Progress < limit, auto-assign it.
    moab web     [--port PORT] start web server (default port: 8770)
    moab -h | --help
                 This usage help message

Common:
  --dir <vault>
                  vault containing board.md (default: auto-detected).
Allowed values:
  --type          feature | bug | chore | spike | docs
  --prio          p1 | p2 | p3
  --agent         cc | opencode | pi | hermes
  --lane / --to   backlog | ready | in-progress | needs-you | done
"""

from __future__ import annotations
import sys, re, datetime, shutil, os, subprocess, time
from pathlib import Path


def lane_of(heading: str):
    h = heading.lower()
    if "ready" in h:
        return ("ready", "ai")
    if "in progress" in h:
        return ("in-progress", "ai")
    if "needs you" in h:
        return ("needs-you", "human")
    if "backlog" in h:
        return ("backlog", "human")
    if "done" in h:
        return ("done", "human")
    return (None, None)


# lane key -> human substring used to locate its '## ' heading on the board
LANE_HEADING = {
    "backlog": "Backlog",
    "ready": "Ready for AI",
    "in-progress": "In Progress",
    "needs-you": "Needs You",
    "done": "Done",
}
PRIO = {"p1", "p2", "p3"}
TYPE = {"feature", "bug", "chore", "spike", "docs"}
AGENT = {"cc", "opencode", "pi", "hermes"}
STATE = {"raw", "blocked", "review"}

CARD_RE = re.compile(r"^-\s*(?:\[[ xX/]\]\s*)?(.*)$")
LINK_RE = re.compile(r"\[\[([^\]|]+?)(?:\|[^\]]+)?\]\]")
TAG_RE = re.compile(r"#([A-Za-z0-9_/-]+)")
DUE_RE = re.compile(r"@\{(\d{4}-\d{2}-\d{2})\}")
TODAY = datetime.date.today().isoformat()


def die(msg: str):
    sys.exit(f"moab: {msg}")


def sanitize_project_name(name: str) -> str:
    name = name.strip()
    name = re.sub(r'[^\w\s.-]', ' ', name)
    name = re.sub(r'[-\s]+', ' ', name)
    name = name.strip(' -_')
    if len(name) > 30:
        name = name[:30].rstrip(' -')
    return name or "project"


def get_project_name(base: Path, cli_name: str | None = None, skip_dashboard=False) -> str:
    if cli_name:
        return sanitize_project_name(cli_name)
    if not skip_dashboard:
        dash = base / "Dashboard.md"
        if dash.exists():
            m = re.search(r'^project_name:\s*(.+)$', dash.read_text(encoding="utf-8"), re.M)
            if m:
                name = m.group(1).strip()
                if name:
                    return name
    try:
        for p in [base] + list(base.parents):
            if (p / ".git").exists():
                r = subprocess.run(["git", "remote", "get-url", "origin"], capture_output=True, text=True, cwd=str(p), timeout=5)
                if r.returncode == 0:
                    url = r.stdout.strip().rstrip("/")
                    name = url.rstrip(".git").split("/")[-1]
                    if name:
                        return sanitize_project_name(name)
                break
    except Exception:
        pass
    return sanitize_project_name(base.resolve().parent.name)


def find_base(cli_dir: str) -> Path:
    if cli_dir:
        return Path(cli_dir).expanduser().resolve()
    here = Path(__file__).resolve().parent.parent
    if (here / "board.md").exists():
        return here
    if (Path.cwd() / "board.md").exists():
        return Path.cwd()
    die("cannot find board.md (pass --dir <vault>)")
    return Path()


# ----- board parsing -----
def parse_board(board: Path):
    status = owner = None
    for raw in board.read_text(encoding="utf-8").splitlines():
        if raw.startswith("## "):
            status, owner = lane_of(raw[3:])
            continue
        if status is None:
            continue
        m = CARD_RE.match(raw)
        if not m:
            continue
        link = LINK_RE.search(m.group(1))
        if not link:
            continue
        tags = {t.lower() for t in TAG_RE.findall(m.group(1))}
        due = DUE_RE.search(m.group(1))
        yield {
            "target": link.group(1).strip(),
            "status": status,
            "owner": owner,
            "agent": next((t for t in AGENT if t in tags), ""),
            "priority": next((t for t in PRIO if t in tags), None),
            "type": next((t for t in TYPE if t in tags), None),
            "state": next((t for t in STATE if t in tags), None),
            "due": due.group(1) if due else None,
        }


# ----- frontmatter -----
def update_frontmatter(text: str, updates: dict) -> tuple[str, list]:
    lines = text.splitlines(keepends=True)
    if not lines or lines[0].strip() != "---":
        return text, []
    end = next((i for i in range(1, len(lines)) if lines[i].strip() == "---"), None)
    if end is None:
        return text, []
    fm, changed = lines[1:end], []
    for key, val in updates.items():
        if val is None:
            continue
        new_line = (f"{key}:" if val == "" else f"{key}: {val}") + "\n"
        pat = re.compile(rf"^{re.escape(key)}\s*:.*$")
        for i, ln in enumerate(fm):
            if pat.match(ln):
                if ln.rstrip("\n") != new_line.rstrip("\n"):
                    fm[i] = new_line
                    changed.append(key)
                break
        else:
            fm.append(new_line)
            changed.append(key)
    if not changed:
        return text, []
    return "".join(lines[:1] + fm + lines[end:]), changed


# ----- formatting -----
def format_note(text: str) -> tuple[str, list[str]]:
    """Auto-fix common Obsidian markdown formatting issues in note body (skip frontmatter).
    Returns (fixed_text, list_of_changes)."""
    m = re.match(r"^(---\n.*?\n---\n)(.*)", text, re.S)
    if not m:
        return text, []
    fm, body = m.group(1), m.group(2)
    lines = body.splitlines(keepends=True)
    changes = []

    # 1. Strip trailing whitespace
    for i, l in enumerate(lines):
        s = l.rstrip() + ("\n" if l.endswith("\n") else "")
        if s != l:
            changes.append(f"trailing whitespace (line {i+1})")
        lines[i] = s

    # 2. Insert blank line after headings (##+) if next line is non-blank
    i = 0
    while i < len(lines) - 1:
        if re.match(r"^#{2,}\s", lines[i]) and lines[i + 1].strip():
            lines.insert(i + 1, "\n")
            changes.append(f"missing blank line after heading (line {i+1})")
            i += 2
        else:
            i += 1

    # 3. Collapse 3+ consecutive blank lines into max 2
    result, blank = [], 0
    for l in lines:
        if not l.strip():
            blank += 1
            if blank <= 2:
                result.append(l)
        else:
            blank = 0
            result.append(l)
    if len(result) != len(lines):
        changes.append("collapsed consecutive blank lines")

    return fm + "".join(result), changes


def format_text(text: str) -> tuple[str, list[str]]:
    """Auto-fix common markdown formatting: trailing whitespace, blank lines after headings,
    collapsing 3+ blank lines, in a block of text that has no frontmatter or protected blocks.
    Returns (fixed_text, list_of_changes)."""
    lines = text.splitlines(keepends=True)
    changes = []

    # 1. Strip trailing whitespace
    for i, l in enumerate(lines):
        s = l.rstrip() + ("\n" if l.endswith("\n") else "")
        if s != l:
            changes.append(f"trailing whitespace (line {i+1})")
        lines[i] = s

    # 2. Insert blank line after headings (##+) if next line is non-blank
    i = 0
    while i < len(lines) - 1:
        if re.match(r"^#{2,}\s", lines[i]) and lines[i + 1].strip():
            lines.insert(i + 1, "\n")
            changes.append(f"blank line after heading (line {i+1})")
            i += 2
        else:
            i += 1

    # 3. Collapse 3+ consecutive blank lines into max 2
    result, blank = [], 0
    for l in lines:
        if not l.strip():
            blank += 1
            if blank <= 2:
                result.append(l)
        else:
            blank = 0
            result.append(l)
    if len(result) != len(lines):
        changes.append("collapsed consecutive blank lines")

    return "".join(result), changes


def format_board(text: str) -> tuple[str, list[str]]:
    """Auto-fix board.md formatting. Preserves frontmatter and kanban settings block.
    Returns (fixed_text, list_of_changes)."""
    # split off frontmatter
    m = re.match(r"^(---\n.*?\n---\n)", text, re.S)
    fm_end = m.end() if m else 0
    body = text[fm_end:]
    # split off settings block
    s = re.search(r"\n%%\s*kanban:settings", body)
    if s:
        body_start = body[:s.start()]
        settings_block = body[s.start():]
    else:
        body_start = body
        settings_block = ""
    fixed, changes = format_text(body_start)
    if changes:
        return text[:fm_end] + fixed + settings_block, changes
    return text, []


def format_note(text: str) -> tuple[str, list[str]]:
    """Auto-fix common Obsidian markdown formatting issues in note body (skip frontmatter).
    Returns (fixed_text, list_of_changes)."""
    m = re.match(r"^(---\n.*?\n---\n)(.*)", text, re.S)
    if not m:
        return text, []
    fm, body = m.group(1), m.group(2)
    fixed, changes = format_text(body)
    if not changes:
        return text, []
    return fm + fixed, changes
def heading_index(lines, lane_key):
    sub = LANE_HEADING[lane_key].lower()
    for i, l in enumerate(lines):
        if l.startswith("## ") and sub in l.lower():
            return i
    die(f"lane '{lane_key}' not found on board")


def section_end(lines, hi):
    for j in range(hi + 1, len(lines)):
        s = lines[j]
        if s.startswith("## ") or s.startswith("%%") or s.startswith("***"):
            return j
    return len(lines)


def insert_card(lines, lane_key, card_line):
    hi = heading_index(lines, lane_key)
    se = section_end(lines, hi)
    # ensure exactly one blank line after heading
    if hi + 1 >= len(lines) or lines[hi + 1].strip() != "":
        lines.insert(hi + 1, "\n")
        se += 1
    # walk back from section end past trailing blank lines
    ip = se
    while ip - 1 > hi and lines[ip - 1].strip() == "":
        ip -= 1
    # stay after the heading blank line
    if ip == hi + 1:
        ip += 1
    lines.insert(ip, card_line)
    # ensure a trailing blank line between the new card and the next section
    if ip + 1 < len(lines) and lines[ip + 1].strip() != "":
        lines.insert(ip + 1, "\n")


def find_card(lines, task_id):
    pat = re.compile(r"\[\[" + re.escape(task_id) + r"[\] |]")
    for i, l in enumerate(lines):
        if l.lstrip().startswith("-") and pat.search(l):
            return i
    return None


def edit_tags(line, add=(), strip=()):
    for t in strip:
        line = re.sub(r"\s*#" + re.escape(t) + r"\b", "", line)
    present = {x.lower() for x in TAG_RE.findall(line)}
    for t in add:
        if t.lower() not in present:
            line = line.rstrip("\n") + f" #{t}\n"
    return line


def append_agent_log(note: Path, agent: str, msg: str):
    lines = note.read_text(encoding="utf-8").splitlines(keepends=True)
    for i, l in enumerate(lines):
        if l.startswith("## ") and "Agent Log" in l:
            j = i + 1
            while j < len(lines) and not lines[j].startswith("## "):
                j += 1
            ip = j
            while ip - 1 > i and lines[ip - 1].strip() == "":
                ip -= 1
            lines.insert(ip, f"- {TODAY} {agent}: {msg}\n")
            note.write_text("".join(lines), encoding="utf-8")
            return True
    return False


def next_id(base: Path) -> str:
    n = 0
    for f in (base / "Backlog").glob("T-*.md"):
        m = re.match(r"T-(\d+)", f.name)
        if m:
            n = max(n, int(m.group(1)))
    return f"T-{n + 1:03d}"


def note_for(base: Path, target: str) -> Path:
    return base / "Backlog" / f"{target}.md"


def find_note(base: Path, target_or_id: str):
    """Best-effort note lookup (returns Path or None, never dies).
    Tolerates trailing spaces and matches by exact name or by T-NNN id."""
    bl = base / "Backlog"
    exact = bl / f"{target_or_id}.md"
    if exact.exists():
        return exact
    tid = target_or_id.split(" ", 1)[0]
    hits = sorted(bl.glob(f"{tid} *.md")) + sorted(bl.glob(f"{tid}.md"))
    return hits[0] if hits else None


def note_for_id(base: Path, task_id: str) -> Path:
    n = find_note(base, task_id)
    if n is None:
        die(f"no note in Backlog/ for '{task_id}'")
    return n


# ----- commands -----
def orphaned_notes(base: Path) -> list[Path]:
    """Return notes in Backlog/ that have no corresponding card on the board."""
    board_targets = {c["target"] for c in parse_board(base / "board.md")}
    orphans = []
    for f in sorted((base / "Backlog").glob("*.md")):
        if f.name == "_Template.md":
            continue
        if f.stem not in board_targets:
            orphans.append(f)
    return orphans


def cmd_sync(base, check=False):
    drift = False

    # format board.md itself
    board = base / "board.md"
    btext = board.read_text(encoding="utf-8")
    bfixed, bchanges = format_board(btext)
    if bchanges:
        drift = True
        for c in bchanges:
            print(f"  ~ board.md: {'would fix ' if check else ''}{c}")
        if not check:
            board.write_text(bfixed, encoding="utf-8")

    def process(note: Path, label: str):
        nonlocal drift
        text = note.read_text(encoding="utf-8")
        upd = {}
        for c in parse_board(base / "board.md"):
            if c["target"] == note.stem:
                upd = {k: c[k] for k in ("status", "owner", "agent", "priority", "type", "state", "due")}
                break
        new, fm_changed = update_frontmatter(text, upd)
        nf, fmt_changed = format_note(new if fm_changed else text)
        if fm_changed:
            drift = True
            print(f"  ✓ {label}: {'would update' if check else 'updated'} {', '.join(fm_changed)}")
        if fmt_changed:
            drift = True
            print(f"  ~ {label}: {'would fix ' if check else ''}{'; '.join(fmt_changed)}")
        if (fm_changed or fmt_changed) and not check:
            note.write_text(nf, encoding="utf-8")

    for c in parse_board(base / "board.md"):
        note = note_for(base, c["target"])
        if not note.exists():
            print(f"  ! {c['target']}: no note in Backlog/ (skipped)")
            continue
        process(note, c["target"])
    orphans = orphaned_notes(base)
    for o in orphans:
        print(f"  ! {o.stem}: note in Backlog/ but no card on board")
        if check:
            drift = True
        else:
            process(o, o.stem)
    if not drift:
        print("  everything in sync ✓")
    return 1 if (check and drift) else 0


def cmd_status(base):
    lanes = {}
    for c in parse_board(base / "board.md"):
        lanes.setdefault(c["status"], []).append(c["target"] + (f"  #{c['agent']}" if c["agent"] else ""))
    for st in ("backlog", "ready", "in-progress", "needs-you", "done"):
        cards = lanes.get(st, [])
        print(f"\n{st}  ({len(cards)})")
        for c in cards:
            print(f"  - {c}")
    orphans = orphaned_notes(base)
    if orphans:
        print(f"\norphaned  ({len(orphans)})")
        for o in orphans:
            print(f"  - {o.stem}")
    return 0


def cmd_new(base, opts):
    title = re.sub(r"\s+", " ", (opts.get("_pos") or "")).strip()  # no trailing/dup spaces
    if not title:
        die('new: need a title, e.g. moab new "Add X" --type chore --prio p3')
    typ = opts.get("type", "chore")
    prio = opts.get("prio", "p2")
    lane = opts.get("lane", "backlog")
    tid = next_id(base)
    note = base / "Backlog" / f"{tid} {title}.md"
    if note.exists():
        die(f"new: {note.name} already exists")
    tpl = (base / "_templates" / "_Template.md").read_text(encoding="utf-8")
    tpl = re.sub(r"<!--.*?-->\n?", "", tpl, flags=re.S)  # drop instruction comment
    tpl = (
        tpl.replace("id: T-000", f"id: {tid}")
        .replace("title: Short imperative title", f"title: {title}")
        .replace("# T-000 — Short imperative title", f"# {tid} — {title}")
        .replace("created: 2026-06-23", f"created: {TODAY}")
        .replace("updated: 2026-06-23", f"updated: {TODAY}")
    )
    note.write_text(tpl, encoding="utf-8")
    tags = f"#{typ} #{prio}" + (" #raw" if opts.get("raw") else "")
    due = f" @{{{opts['due']}}}" if opts.get("due") else ""
    card = f"- [ ] [[{tid} {title}]] {tags}{due}\n"
    board = base / "board.md"
    lines = board.read_text(encoding="utf-8").splitlines(keepends=True)
    insert_card(lines, lane, card)
    board.write_text("".join(lines), encoding="utf-8")
    print(f"  ✓ created {tid} in {lane}: {note.name}")
    return cmd_sync(base)


def _move(base, task_id, to_lane, add=(), strip=(), agent=None, log=None):
    board = base / "board.md"
    lines = board.read_text(encoding="utf-8").splitlines(keepends=True)
    idx = find_card(lines, task_id)
    if idx is None:
        die(f"card '{task_id}' not found on board")
    line = lines.pop(idx)
    # clean up orphaned blank line left by the removed card
    if idx < len(lines) and lines[idx].strip() == "":
        lines.pop(idx)
    addt = list(add) + ([agent] if agent else [])
    line = edit_tags(line, add=addt, strip=strip)
    insert_card(lines, to_lane, line)
    board.write_text("".join(lines), encoding="utf-8")
    if agent and log:
        target = LINK_RE.search(line).group(1).strip()
        note = find_note(base, target)
        if note:
            append_agent_log(note, agent, log)
        else:
            print(f"  ! {target}: brak notatki — wpis do Agent Log pominięty")
    print(f"  ✓ {task_id} → {to_lane}" + (f"  #{agent}" if agent else ""))
    return cmd_sync(base)


def cmd_claim(base, opts):
    agent = opts.get("agent")
    if not agent or agent not in AGENT:
        die(f"claim: --agent must be one of {sorted(AGENT)}")
    return _move(base, opts.get("_pos"), "in-progress", strip=STATE, agent=agent, log="claimed, starting")


def cmd_retag(base, opts):
    tid = opts.get("_pos")
    if not tid:
        die("retag: need <id>")
    board = base / "board.md"
    lines = board.read_text(encoding="utf-8").splitlines(keepends=True)
    idx = find_card(lines, tid)
    if idx is None:
        die(f"retag: card '{tid}' not found on board")
    add, strip = [], []
    if opts.get("prio"):
        if opts["prio"] not in PRIO:
            die(f"retag: --prio must be one of {sorted(PRIO)}")
        strip += list(PRIO)
        add.append(opts["prio"])
    if opts.get("type"):
        if opts["type"] not in TYPE:
            die(f"retag: --type must be one of {sorted(TYPE)}")
        strip += list(TYPE)
        add.append(opts["type"])
    if opts.get("add"):
        add.append(opts["add"].lstrip("#"))
    if opts.get("remove"):
        strip.append(opts["remove"].lstrip("#"))
    if not (add or strip):
        die("retag: nothing to change (use --prio/--type/--add/--remove)")
    lines[idx] = edit_tags(lines[idx], add=add, strip=strip)
    board.write_text("".join(lines), encoding="utf-8")
    print(f"  ✓ {tid} retagged")
    return cmd_sync(base)


def cmd_rm(base, opts):
    tid = opts.get("_pos")
    if not tid:
        die("rm: need <id>")
    board = base / "board.md"
    lines = board.read_text(encoding="utf-8").splitlines(keepends=True)
    idx = find_card(lines, tid)
    target = None
    if idx is not None:
        target = LINK_RE.search(lines[idx]).group(1).strip()
        lines.pop(idx)
        board.write_text("".join(lines), encoding="utf-8")
    note = find_note(base, target or tid)
    if note and note.exists():
        note.unlink()
    print(f"  ✓ removed {tid}" + ("" if (idx is not None or note) else " (nothing found)"))
    return 0


def cmd_review(base, opts):
    return _move(
        base,
        opts.get("_pos"),
        "needs-you",
        add=("review",),
        strip=("blocked", "raw"),
        agent=opts.get("agent"),
        log=opts.get("note", "ready for review"),
    )


def cmd_block(base, opts):
    return _move(
        base,
        opts.get("_pos"),
        "needs-you",
        add=("blocked",),
        strip=("review",),
        agent=opts.get("agent"),
        log=opts.get("note", "blocked, needs input"),
    )


def cmd_done(base, opts):
    return _move(base, opts.get("_pos"), "done", strip=STATE)


def _set_project_name(dst: Path, name: str):
    dash = dst / "Dashboard.md"
    if dash.exists():
        text = dash.read_text(encoding="utf-8")
        new_text, _ = update_frontmatter(text, {"project_name": name})
        if new_text != text:
            dash.write_text(new_text, encoding="utf-8")
    css = dst / ".obsidian" / "snippets" / "moab-board.css"
    if css.exists():
        text = css.read_text(encoding="utf-8")
        text = text.replace("__PROJECT_NAME__", name)
        css.write_text(text, encoding="utf-8")


def _strip_demo(dst: Path):
    for f in (dst / "Backlog").glob("T-*.md"):
        f.unlink()
    board = dst / "board.md"
    lines = [
        l for l in board.read_text(encoding="utf-8").splitlines(keepends=True) if not re.match(r"^- \[[ xX/]\] \[\[", l)
    ]  # drop task cards, keep hint cards
    board.write_text("".join(lines), encoding="utf-8")


def cmd_install(base, opts):
    target = opts.get("_pos")
    if not target:
        die("install: need a project dir, e.g. moab install ~/Projects/mygame")
    tdir = Path(target).expanduser().resolve()
    if not tdir.is_dir():
        die(f"install: {tdir} is not a directory")
    dst = tdir / "Tasks"
    if dst.exists():
        die(f"install: {dst} already exists — refusing to overwrite")
    # copy the template; exclude per-machine binaries (re-added via flags) + caches
    shutil.copytree(
        base,
        dst,
        ignore=shutil.ignore_patterns(
            "plugins", "themes", "workspace.json", "workspace-mobile.json", ".trash", "__pycache__", ".venv"
        ),
    )
    if not opts.get("keep-demo"):
        _strip_demo(dst)
    if opts.get("with-plugins"):
        for p in ("obsidian-kanban", "dataview", "obsidian-tasks-plugin", "templater-obsidian"):
            src = base / ".obsidian" / "plugins" / p
            if src.is_dir():
                shutil.copytree(src, dst / ".obsidian" / "plugins" / p, dirs_exist_ok=True)
                print(f"  ✓ plugin {p}")
    if opts.get("with-theme"):
        src = base / ".obsidian" / "themes" / "Obsidianite"
        if src.is_dir():
            shutil.copytree(src, dst / ".obsidian" / "themes" / "Obsidianite", dirs_exist_ok=True)
            print("  ✓ theme Obsidianite")
    pname = get_project_name(dst, opts.get("project-name"), skip_dashboard=True)
    _set_project_name(dst, pname)
    print(f"  ✓ project name: {pname}")
    if opts.get("hook"):
        hooks = tdir / ".git" / "hooks"
        if hooks.is_dir():
            link = hooks / "pre-commit"
            link.unlink(missing_ok=True)
            os.symlink("../../Tasks/bin/pre-commit", link)
            print("  ✓ pre-commit hook")
        else:
            print("  ! no .git/hooks — skipped hook (run `git init` first)")
    print(f"  ✓ MOAB installed at {dst}")
    print(f'    next: python3 {dst.name}/bin/moab new "..." --type feature --prio p2')
    return 0


def cmd_assign(base, opts):
    tid = opts.get("_pos")
    agent = opts.get("agent", "opencode")
    if not tid:
        die("assign: need <id>, e.g. moab assign T-003 --agent opencode")
    if agent not in AGENT:
        die(f"assign: --agent must be one of {sorted(AGENT)}")
    note = note_for_id(base, tid)
    prompt = (
        f"Jesteś agentem '{agent}' pracującym nad projektem {pname}. "
        f"Twoje zadanie to {tid}. "
        f"Przeczytaj najpierw AGENTS.md głównego projektu oraz notatkę zadania Tasks/Backlog/{note.name}, "
        f"a następnie zclaimuj zadanie komendą: python3 Tasks/bin/moab claim {tid} --agent {agent}. "
        f"Zrealizuj je zgodnie z sekcjami Goal, Plan, Definition of Done i Constraints. "
    )
    if opts.get("long"):
        prompt += (
            f"Zaimplementuj je zgodnie z notatką 'Tasks/Backlog/{note.name}' i sekcją Constraints. "
            f"Po skończeniu: python3 Tasks/bin/moab review {tid} --agent {agent} --note '<co zrobiono, jak przetestować>'. "
            f"Jeśli zablokowany: python3 Tasks/bin/moab block {tid} --agent {agent} --note '<pytanie>'."
        )
    mflag = ["-m", opts["model"]] if opts.get("model") else []
    pname = get_project_name(base, None)
    if agent == "opencode":
        cmd = ["opencode", "run", "--dangerously-skip-permissions", "--title", f"{pname}: {tid}", *mflag, prompt]
    else:
        cmd = ["opencode", "run", *mflag, prompt]
    if opts.get("run"):
        project_root = str(base.parent)
        env = os.environ.copy()
        env["PWD"] = project_root
        return subprocess.call(cmd, cwd=project_root, env=env)  # run from project root
    # default: print a copy-pasteable command (run from the project root)
    extra = f'-m "{opts["model"]}" ' if opts.get("model") else ""
    if agent == "opencode":
        extra += f'--dangerously-skip-permissions --title "{pname}: {tid}" '
    printable = f"opencode run {extra}" + f'"{prompt}"'
    print(printable)
    return 0


def cmd_log(base, opts):
    agent = opts.get("agent")
    note = opts.get("note")
    if not agent or not note:
        die('log: need --agent <name> and --note "<text>"')
    append_agent_log(note_for_id(base, opts.get("_pos")), agent, note)
    print(f"  ✓ logged on {opts.get('_pos')}")
    return 0


def cmd_move(base, opts):
    to = opts.get("to")
    if to not in LANE_HEADING:
        die(f"move: --to must be one of {list(LANE_HEADING)}")
    add = [t for t in ("review", "blocked", "raw") if opts.get(t)]
    return _move(base, opts.get("_pos"), to, add=add, agent=opts.get("agent"))


def cmd_watch(base, opts):
    agent = opts.get("agent")
    if not agent:
        die("watch: need --agent <name>")
    interval = int(opts.get("interval", 10))
    limit = int(opts.get("limit", 1))
    model = opts.get("model")
    print(f"  watching board every {interval}s (WIP limit: {limit}, agent: {agent})")
    try:
        while True:
            cards = list(parse_board(base / "board.md"))
            ready = [c for c in cards if c["status"] == "ready"]
            in_progress = [c for c in cards if c["status"] == "in-progress"]
            if ready and len(in_progress) < limit:
                tid = ready[0]["target"]
                print(f"  → assigning {tid}")
                assign_opts = {
                    "_pos": tid.split(" ", 1)[0],
                    "agent": agent,
                    "run": True,
                    "model": model,
                }
                cmd_assign(base, assign_opts)
            time.sleep(interval)
    except KeyboardInterrupt:
        print("\n  watch stopped")
    return 0


def cmd_web(base: Path, opts: dict):
    cmd = str(base / "web" / "run.sh")
    port = opts.get("port")
    if port:
        subprocess.call([cmd, port])
    else:
        subprocess.call([cmd])


# ----- arg parsing -----
FLAGS = {
    "check",
    "raw",
    "review",
    "blocked",  # boolean
    "with-plugins",
    "with-theme",
    "hook",
    "keep-demo",
    "run",
    "long",
}
VALS = {"type", "prio", "lane", "agent", "model", "due", "to", "dir", "note", "add", "remove", "port", "project-name", "interval", "limit"}  # take a value


def parse_args(argv):
    opts, i = {}, 0
    while i < len(argv):
        a = argv[i]
        if a.startswith("--"):
            k = a[2:]
            if k in FLAGS:
                opts[k] = True
            elif k in VALS:
                i += 1
                opts[k] = argv[i] if i < len(argv) else None
            else:
                die(f"unknown option --{k}")
        else:
            opts["_pos"] = a if "_pos" not in opts else opts["_pos"]
        i += 1
    return opts


def main(argv):
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(__doc__.strip())
        return 0
    cmd, opts = argv[0], parse_args(argv[1:])
    base = find_base(opts.get("dir"))
    table = {
        "sync": lambda: cmd_sync(base, opts.get("check", False)),
        "status": lambda: cmd_status(base),
        "new": lambda: cmd_new(base, opts),
        "claim": lambda: cmd_claim(base, opts),
        "review": lambda: cmd_review(base, opts),
        "block": lambda: cmd_block(base, opts),
        "done": lambda: cmd_done(base, opts),
        "log": lambda: cmd_log(base, opts),
        "move": lambda: cmd_move(base, opts),
        "retag": lambda: cmd_retag(base, opts),
        "rm": lambda: cmd_rm(base, opts),
        "install": lambda: cmd_install(base, opts),
        "assign": lambda: cmd_assign(base, opts),
        "watch": lambda: cmd_watch(base, opts),
        "web": lambda: cmd_web(base, opts),
    }
    if cmd not in table:
        die(f"unknown command '{cmd}' (try `moab --help`)")
    return table[cmd]()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
