{
    "$defs": {
        "AttitudeEnum": {
            "enum": [
                "friendly",
                "afraid",
                "enemy"
            ],
            "title": "AttitudeEnum",
            "type": "string"
        },
        "Character": {
            "additionalProperties": false,
            "properties": {
                "name_EN": {
                    "description": "English character name",
                    "minLength": 1,
                    "title": "Name En",
                    "type": "string"
                },
                "name_PL": {
                    "description": "Polish character name",
                    "minLength": 1,
                    "title": "Name Pl",
                    "type": "string"
                },
                "sprite": {
                    "description": "Must be valid file name from assets folder",
                    "minLength": 3,
                    "title": "Sprite",
                    "type": "string"
                },
                "race": {
                    "$ref": "#/$defs/RaceEnum",
                    "description": "Base character race (e.g. humanoid, animal)"
                },
                "attitude": {
                    "$ref": "#/$defs/AttitudeEnum",
                    "description": "Attitude towards the player"
                },
                "is_merchant": {
                    "default": false,
                    "description": "Flag if NPC can trade items",
                    "title": "Is Merchant",
                    "type": "boolean"
                },
                "tradeable_items_types": {
                    "description": "Item's type that can be traded. Empty means all.",
                    "items": {
                        "$ref": "#/$defs/ItemTypeEnum"
                    },
                    "title": "Tradeable Items Types",
                    "type": "array"
                },
                "allowed_zones": {
                    "description": "Zones where the character is allowed to move. Empty means everywhere.",
                    "items": {
                        "type": "string"
                    },
                    "title": "Allowed Zones",
                    "type": "array"
                },
                "health": {
                    "default": 30,
                    "description": "initial health value",
                    "minimum": 0,
                    "title": "Health",
                    "type": "integer"
                },
                "max_health": {
                    "default": 30,
                    "description": "maximal health value",
                    "minimum": 0,
                    "title": "Max Health",
                    "type": "integer"
                },
                "items": {
                    "description": "list of character's items",
                    "items": {
                        "type": "string"
                    },
                    "title": "Items",
                    "type": "array"
                },
                "max_carry_weight": {
                    "default": 15.0,
                    "description": "maximal carrying weight in kg",
                    "minimum": 0.0,
                    "title": "Max Carry Weight",
                    "type": "number"
                },
                "money": {
                    "default": 0,
                    "description": "initial amount of possessed money",
                    "minimum": 0,
                    "title": "Money",
                    "type": "integer"
                },
                "damage": {
                    "default": 10,
                    "description": "amount of damage delt to others",
                    "minimum": 0,
                    "title": "Damage",
                    "type": "integer"
                },
                "speed_walk": {
                    "default": 30,
                    "description": "walking speed",
                    "gr": 0,
                    "title": "Speed Walk",
                    "type": "integer"
                },
                "speed_run": {
                    "default": 40,
                    "description": "walking speed",
                    "gr": 0,
                    "title": "Speed Run",
                    "type": "integer"
                },
                "has_dialog": {
                    "default": false,
                    "description": "Whether this character has a dialog graph",
                    "title": "Has Dialog",
                    "type": "boolean"
                },
                "friendly": {
                    "default": 0.5,
                    "description": "Base sentiment towards the player (0..1, maps to initial NPC sentiment 0..100)",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Friendly",
                    "type": "number"
                },
                "disposition": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "additionalProperties": {
                                "type": "integer"
                            },
                            "type": "object"
                        }
                    ],
                    "description": "Per-sentiment weights that shift NPC sentiment when a dialog option is chosen; legacy int is converted to default weights",
                    "title": "Disposition"
                }
            },
            "required": [
                "name_EN",
                "name_PL",
                "sprite",
                "race",
                "attitude"
            ],
            "title": "Character",
            "type": "object"
        },
        "Chest": {
            "additionalProperties": false,
            "properties": {
                "name": {
                    "description": "Chest display name",
                    "minLength": 3,
                    "title": "Name",
                    "type": "string"
                },
                "is_small": {
                    "default": true,
                    "description": "Is it small or big",
                    "title": "Is Small",
                    "type": "boolean"
                },
                "is_closed": {
                    "default": true,
                    "description": "Is it closed or open",
                    "title": "Is Closed",
                    "type": "boolean"
                },
                "items": {
                    "description": "list of persistent items in the chest",
                    "items": {
                        "type": "string"
                    },
                    "title": "Items",
                    "type": "array"
                },
                "total_items_count": {
                    "default": 0,
                    "description": "total numer of items to generate (persistent + random)",
                    "title": "Total Items Count",
                    "type": "integer"
                },
                "random_items": {
                    "description": "list of items to generate randomly",
                    "items": {
                        "type": "string"
                    },
                    "title": "Random Items",
                    "type": "array"
                }
            },
            "required": [
                "name"
            ],
            "title": "Chest",
            "type": "object"
        },
        "CompletionMode": {
            "description": "How a quest decides it is finished (decision D5).\n\nExplicit rather than inferred — this enum is the whole reason the\n``Q01_S07`` class of bug cannot be expressed any more.",
            "enum": [
                "all_subquests",
                "test",
                "manual"
            ],
            "title": "CompletionMode",
            "type": "string"
        },
        "Item": {
            "additionalProperties": false,
            "properties": {
                "name_EN": {
                    "description": "English item name",
                    "minLength": 1,
                    "title": "Name En",
                    "type": "string"
                },
                "name_PL": {
                    "description": "Polish item name",
                    "minLength": 1,
                    "title": "Name Pl",
                    "type": "string"
                },
                "type": {
                    "$ref": "#/$defs/ItemTypeEnum",
                    "description": "Item type (e.g. weapon, tool, consumable)"
                },
                "value": {
                    "default": 50,
                    "description": "Monetary value",
                    "minimum": 0,
                    "title": "Value",
                    "type": "integer"
                },
                "in_use": {
                    "default": false,
                    "description": "Whether the item is currently in use",
                    "title": "In Use",
                    "type": "boolean"
                },
                "count": {
                    "default": 1,
                    "description": "Number of items in the stack",
                    "minimum": 1,
                    "title": "Count",
                    "type": "integer"
                },
                "weight": {
                    "default": 1.0,
                    "description": "Weight of single item in the stack in kg",
                    "minimum": 0.0,
                    "title": "Weight",
                    "type": "number"
                },
                "health_impact": {
                    "default": 0,
                    "description": "The impact on health when consumed",
                    "minimum": 0,
                    "title": "Health Impact",
                    "type": "integer"
                },
                "damage": {
                    "default": 10,
                    "description": "The amount of damage delt (weapon only)",
                    "minimum": 0,
                    "title": "Damage",
                    "type": "integer"
                },
                "cooldown_time": {
                    "default": 1.0,
                    "description": "The amount of time in seconds it takes to use the weapon again",
                    "minimum": 0.0,
                    "title": "Cooldown Time",
                    "type": "number"
                }
            },
            "required": [
                "name_EN",
                "name_PL",
                "type"
            ],
            "title": "Item",
            "type": "object"
        },
        "ItemTypeEnum": {
            "enum": [
                "weapon",
                "key",
                "consumable",
                "money",
                "gem"
            ],
            "title": "ItemTypeEnum",
            "type": "string"
        },
        "MazeLevelProperties": {
            "additionalProperties": false,
            "properties": {
                "monsters_list": {
                    "description": "List of regular monster NPC models names",
                    "items": {
                        "type": "string"
                    },
                    "title": "Monsters List",
                    "type": "array"
                },
                "boss_monster": {
                    "description": "Boss monster NPC model name",
                    "minLength": 3,
                    "title": "Boss Monster",
                    "type": "string"
                },
                "monsters_count": {
                    "default": 1,
                    "description": "Number of regular monster per level (without boss)",
                    "minimum": 0,
                    "title": "Monsters Count",
                    "type": "integer"
                },
                "small_chest_count": {
                    "default": 1,
                    "description": "Number of small chests on the map",
                    "minimum": 0,
                    "title": "Small Chest Count",
                    "type": "integer"
                },
                "small_chest_template": {
                    "description": "Small chest name from config",
                    "minLength": 3,
                    "title": "Small Chest Template",
                    "type": "string"
                },
                "big_chest_template": {
                    "description": "Big chest name from config",
                    "minLength": 3,
                    "title": "Big Chest Template",
                    "type": "string"
                },
                "maze_cols": {
                    "default": 5,
                    "description": "Number of columns in map grid",
                    "minimum": 0,
                    "title": "Maze Cols",
                    "type": "integer"
                },
                "maze_rows": {
                    "default": 5,
                    "description": "Number of rows in map grid",
                    "minimum": 0,
                    "title": "Maze Rows",
                    "type": "integer"
                }
            },
            "required": [
                "boss_monster",
                "small_chest_template",
                "big_chest_template"
            ],
            "title": "MazeLevelProperties",
            "type": "object"
        },
        "Quest": {
            "additionalProperties": false,
            "properties": {
                "name": {
                    "description": "`messages` key of the quest title",
                    "minLength": 1,
                    "title": "Name",
                    "type": "string"
                },
                "description": {
                    "description": "`messages` key of the quest description",
                    "minLength": 1,
                    "title": "Description",
                    "type": "string"
                },
                "success": {
                    "description": "`messages` key of the completion text; plain prose, the reward label is appended by the engine",
                    "minLength": 1,
                    "title": "Success",
                    "type": "string"
                },
                "completion": {
                    "$ref": "#/$defs/CompletionMode",
                    "description": "How the quest completes: all_subquests / test / manual"
                },
                "test": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Mini-DSL condition; required by (and only by) completion='test'",
                    "title": "Test"
                },
                "progress": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Mini-DSL numeric expression for the progress bar; pairs with progress_total",
                    "title": "Progress"
                },
                "progress_total": {
                    "default": 0,
                    "description": "Denominator of the progress bar; 0 means no explicit progress",
                    "minimum": 0,
                    "title": "Progress Total",
                    "type": "integer"
                },
                "requires": {
                    "description": "Quest keys that must be done before this one unlocks (DAG edges)",
                    "items": {
                        "type": "string"
                    },
                    "title": "Requires",
                    "type": "array"
                },
                "parent": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Umbrella quest this one is a subquest of",
                    "title": "Parent"
                },
                "rewards": {
                    "description": "Effects applied on completion; ALL of them, in order",
                    "items": {
                        "$ref": "#/$defs/QuestReward"
                    },
                    "title": "Rewards",
                    "type": "array"
                }
            },
            "required": [
                "name",
                "description",
                "success",
                "completion"
            ],
            "title": "Quest",
            "type": "object"
        },
        "QuestReward": {
            "additionalProperties": false,
            "properties": {
                "category": {
                    "$ref": "#/$defs/QuestRewardCategory",
                    "description": "Which stat/resource the reward grants"
                },
                "value": {
                    "default": 0,
                    "description": "Amount granted; unused by the 'items' category",
                    "minimum": 0,
                    "title": "Value",
                    "type": "integer"
                },
                "items": {
                    "description": "Item keys granted; 'items' category only",
                    "items": {
                        "type": "string"
                    },
                    "title": "Items",
                    "type": "array"
                },
                "target": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "NPC config key a 'sentiment' reward applies to; a quest has no current character",
                    "title": "Target"
                }
            },
            "required": [
                "category"
            ],
            "title": "QuestReward",
            "type": "object"
        },
        "QuestRewardCategory": {
            "description": "What a reward gives. Maps 1:1 onto a ``ResultSink`` call in Q-05.\n\nPer decision D11 the SSiS stats were remapped onto stats MoM actually has:\n``hp`` -> :attr:`damage`, ``eloquence`` -> :attr:`sentiment`; ``agility``\nwas dropped (MoM has no such stat) and ``max_items`` needs\n``MAX_HOTBAR_ITEMS`` promoted from a module constant to a player field.",
            "enum": [
                "money",
                "items",
                "health",
                "max_health",
                "damage",
                "max_items",
                "sentiment"
            ],
            "title": "QuestRewardCategory",
            "type": "string"
        },
        "RaceEnum": {
            "enum": [
                "humanoid",
                "animal",
                "monster"
            ],
            "title": "RaceEnum",
            "type": "string"
        }
    },
    "additionalProperties": false,
    "properties": {
        "characters": {
            "additionalProperties": {
                "$ref": "#/$defs/Character"
            },
            "title": "Characters",
            "type": "object"
        },
        "chests": {
            "additionalProperties": {
                "$ref": "#/$defs/Chest"
            },
            "title": "Chests",
            "type": "object"
        },
        "items": {
            "additionalProperties": {
                "$ref": "#/$defs/Item"
            },
            "title": "Items",
            "type": "object"
        },
        "maze_configs": {
            "additionalProperties": {
                "$ref": "#/$defs/MazeLevelProperties"
            },
            "title": "Maze Configs",
            "type": "object"
        },
        "dialogs": {
            "description": "Character dialog graphs keyed by character config key",
            "title": "Dialogs",
            "type": "object"
        },
        "quests": {
            "additionalProperties": {
                "$ref": "#/$defs/Quest"
            },
            "description": "Quest definitions keyed by quest key",
            "title": "Quests",
            "type": "object"
        },
        "messages": {
            "additionalProperties": {
                "additionalProperties": {
                    "type": "string"
                },
                "type": "object"
            },
            "description": "Localized UI strings keyed by language",
            "title": "Messages",
            "type": "object"
        },
        "$schema": "./config_schema.json"
    },
    "required": [
        "characters",
        "chests",
        "items",
        "maze_configs"
    ],
    "title": "ConfigForSchemaGen",
    "type": "object"
}