[
    {
        "name": "Display Settings Flow",
        "actions": [
            { "label": "Screenshot 1", "commands": ["screenshot"] },
            { "label": "Navigate to Settings", "commands": ["down", "accept"] },
            { "label": "Screenshot 2", "commands": ["screenshot"] },
            { "label": "Changing resolution", "commands": ["down", "accept"] },
            { "label": "Screenshot 3", "commands": ["screenshot"] },
            { "label": "Applying changes", "commands": ["accept"] },
            { "label": "Screenshot 4", "commands": ["screenshot"] },
            { "label": "Verifying settings", "commands": ["debug_settings"] },
            { "label": "Final Screenshot", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Save and Load Basic",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Scene loaded", "commands": ["screenshot"] },
            { "label": "Quick Save (F5)", "commands": ["quick_save", "screenshot"] },
            { "label": "Open LoadPanel (F9)", "commands": ["quick_load", "screenshot"] },
            { "label": "Confirm load", "commands": ["accept", "screenshot"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "After load", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Quick Save and Load",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Starting position", "commands": ["screenshot"] },
            { "label": "Quick Save (F5)", "commands": ["quick_save"] },
            { "label": "Move right", "commands": ["right:30", "screenshot"] },
            { "label": "Open LoadPanel", "commands": ["quick_load"] },
            { "label": "Select slot + confirm", "commands": ["accept"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "Back at start position", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Death then Load",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Save before death", "commands": ["quick_save", "screenshot"] },
            { "label": "Trigger death screen", "commands": ["debug_death_screen"], "wait": 1.0 },
            { "label": "Death screen visible", "commands": ["screenshot"] },
            { "label": "Select slot and confirm load", "commands": ["accept", "accept"], "wait": 2.0 },
            { "label": "Back in game after load", "commands": ["screenshot"] }
        ]
