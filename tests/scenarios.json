    {
        "name": "Multiple Quick Saves",
        "cleanup_saves": [0, 1, 2],
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "First quick save", "commands": ["quick_save", "screenshot"] },
            { "label": "Change game state", "commands": ["right:30"] },
            { "label": "Second quick save", "commands": ["quick_save", "screenshot"] },
            { "label": "Open LoadPanel", "commands": ["quick_load"] },
            { "label": "Select second slot", "commands": ["down", "accept"] },
            { "label": "Confirm", "commands": ["accept"], "wait": 2.0 },
            { "label": "After loading second save", "commands": ["screenshot"] }
        ],
        "assertions": [
            { "type": "file_exists", "path": "<save_dir>/save_0.mom", "min_size": 100 },
            { "type": "file_exists", "path": "<save_dir>/save_1.mom", "min_size": 100 }
        ]
    },
    {
        "name": "Auto Save on Map Change",
        "cleanup_saves": [0],
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Starting position", "commands": ["screenshot"] },
            { "label": "Change map (triggers auto-save)", "commands": ["debug_map_change"], "wait": 2.0 },
