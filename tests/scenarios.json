            { "label": "Close panel", "commands": ["quick_load"] },
            { "label": "Panel closed", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Web Save in localStorage",
        "platform": "web",
        "cleanup_saves": [0],
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
