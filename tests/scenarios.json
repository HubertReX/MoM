[
    {
        "name": "Display Settings Flow",
        "actions": [
            { "label": "Screenshot 1", "commands": ["screenshot"] },
            { "label": "Navigate to Settings", "commands": ["down", "accept"] },
            { "label": "Screenshot 2", "commands": ["screenshot"] },
            { "label": "Changing resolution", "commands": ["down", "accept"] },
            { "label": "Screenshot 3", "commands": ["screenshot"] },
            { "label": "Applying changes", "commands": ["accept"] },
            { "label": "Screenshot 4", "commands": ["screenshot"] },
            { "label": "Verifying settings", "commands": ["debug_settings"] },
            { "label": "Final Screenshot", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Save and Load Basic",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Scene loaded", "commands": ["screenshot"] },
            { "label": "Quick Save (F5)", "commands": ["quick_save", "screenshot"] },
            { "label": "Open LoadPanel (F9)", "commands": ["quick_load", "screenshot"] },
            { "label": "Confirm load", "commands": ["accept", "screenshot"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "After load", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Quick Save and Load",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Starting position", "commands": ["screenshot"] },
            { "label": "Quick Save (F5)", "commands": ["quick_save"] },
            { "label": "Move right", "commands": ["right:30", "screenshot"] },
            { "label": "Open LoadPanel", "commands": ["quick_load"] },
            { "label": "Select slot + confirm", "commands": ["accept"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "Back at start position", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Death then Load",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Save before death", "commands": ["quick_save", "screenshot"] },
            { "label": "Trigger death screen", "commands": ["debug_death_screen"], "wait": 1.0 },
            { "label": "Death screen visible", "commands": ["screenshot"] },
            { "label": "Select slot and confirm load", "commands": ["accept", "accept"], "wait": 2.0 },
            { "label": "Back in game after load", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Multiple Quick Saves",
        "cleanup_saves": [0, 1, 2],
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "First quick save", "commands": ["quick_save", "screenshot"] },
            { "label": "Change game state", "commands": ["right:30"] },
            { "label": "Second quick save", "commands": ["quick_save", "screenshot"] },
            { "label": "Open LoadPanel", "commands": ["quick_load"] },
            { "label": "Select second slot", "commands": ["down", "accept"] },
            { "label": "Confirm", "commands": ["accept"], "wait": 2.0 },
            { "label": "After loading second save", "commands": ["screenshot"] }
        ],
        "assertions": [
            { "type": "file_exists", "path": "<save_dir>/save_0.mom", "min_size": 100 },
            { "type": "file_exists", "path": "<save_dir>/save_1.mom", "min_size": 100 }
        ]
    },
    {
        "name": "Auto Save on Map Change",
        "cleanup_saves": [0],
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Starting position", "commands": ["screenshot"] },
            { "label": "Change map (triggers auto-save)", "commands": ["debug_map_change"], "wait": 2.0 },
            { "label": "New map loaded", "commands": ["screenshot"] },
            { "label": "Open LoadPanel to verify auto-save", "commands": ["quick_load"] },
            { "label": "Auto-save slot visible", "commands": ["screenshot"] },
            { "label": "Close LoadPanel", "commands": ["quick_load"] },
            { "label": "Panel closed", "commands": ["screenshot"] }
        ],
        "assertions": [
            { "type": "file_exists", "path": "<save_dir>/save_0.mom", "min_size": 100 }
        ]
    },
    {
        "name": "Corrupt Save Handling",
        "platform": ["desktop", "web"],
        "setup_saves": [ { "slot": 0, "type": "corrupt" } ],
        "actions": [
            { "label": "Start game with corrupt save", "commands": ["accept"], "wait": 3.0 },
            { "label": "Open LoadPanel", "commands": ["quick_load"] },
            { "label": "Corrupt save silently ignored - panel shown", "commands": ["screenshot"] },
            { "label": "Close panel", "commands": ["quick_load"] },
            { "label": "Panel closed", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Empty Slot Load",
        "actions": [
            { "label": "Start New Game (no saves)", "commands": ["accept"], "wait": 3.0 },
            { "label": "Open LoadPanel (should be empty)", "commands": ["quick_load"] },
            { "label": "Panel open", "commands": ["screenshot"] },
            { "label": "Close panel", "commands": ["quick_load"] },
            { "label": "Panel closed", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "Load from Main Menu",
        "cleanup_saves": [0],
        "actions": [
            { "label": "Create save via new game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Quick save", "commands": ["quick_save"] },
            { "label": "Open main menu", "commands": ["menu"], "wait": 1.0 },
            { "label": "Menu visible", "commands": ["screenshot"] },
            { "label": "Select Load", "commands": ["down", "accept"], "wait": 1.0 },
            { "label": "Load panel visible", "commands": ["screenshot"] },
            { "label": "Confirm load", "commands": ["accept"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "Back in game", "commands": ["screenshot"] }
        ],
        "assertions": [
            { "type": "file_exists", "path": "<save_dir>/save_0.mom", "min_size": 100 }
        ]
    },
    {
        "name": "UI Flow - Full Save Load",
        "actions": [
            { "label": "Start New Game", "commands": ["accept"], "wait": 3.0 },
            { "label": "Quick Save", "commands": ["quick_save"] },
            { "label": "Game saved notification", "commands": ["screenshot"] },
            { "label": "Open LoadPanel", "commands": ["quick_load", "screenshot"] },
            { "label": "Select save and confirm", "commands": ["accept"] },
            { "label": "Confirm dialog", "commands": ["screenshot"] },
            { "label": "Activate load", "commands": ["accept"], "wait": 2.0 },
            { "label": "Game loaded", "commands": ["screenshot"] }
        ]
    },
    {
        "name": "TextInput Basic",
        "actions": [
            { "label": "Open TextInput demo", "commands": ["debug_text_input"], "wait": 1.0 },
            { "label": "Empty fields, first focused", "commands": ["screenshot"] },
            { "label": "Type into free-text field", "commands": ["type:Hello123"], "wait": 0.4 },
            { "label": "Free-text field shows Hello123", "commands": ["screenshot"] },
            { "label": "Focus digits field", "commands": ["down"], "wait": 0.3 },
            { "label": "Type digits + letters over the limit", "commands": ["type:12ab3456"], "wait": 0.4 },
            { "label": "Digits filter + max_length keep 123456", "commands": ["screenshot"] },
            { "label": "Focus password field", "commands": ["down"], "wait": 0.3 },
            { "label": "Type a secret", "commands": ["type:secret"], "wait": 0.4 },
            { "label": "Password masks display (value=secret)", "commands": ["screenshot"] },
            { "label": "Focus latin field", "commands": ["down"], "wait": 0.3 },
            { "label": "Type latin letters and a digit", "commands": ["type:Kate9"], "wait": 0.4 },
            { "label": "Latin filter rejects digit 9 (keeps Kate)", "commands": ["screenshot"] },
            { "label": "Backspace removes last char (keeps Kat)", "commands": ["backspace"], "wait": 0.4 },
            { "label": "Final state", "commands": ["screenshot"] }
        ]
    }
