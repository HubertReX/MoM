# Obsidian mini-vault: keep config + look, drop per-machine binaries + cache.
# Plugin binaries and theme are re-copied per machine (or installed in Obsidian):
#   cp -r ~/ObsidianNotesSync/.obsidian/plugins/obsidian-kanban .obsidian/plugins/
#   cp -r ~/ObsidianNotesSync/.obsidian/themes/Obsidianite  .obsidian/themes/
# appearance.json IS tracked so cssTheme + accent travel (theme just needs installing).
# .obsidian/plugins/
# .obsidian/themes/
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.trash/
web/.venv/
__pycache__/
